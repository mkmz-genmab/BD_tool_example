PORT=5000

# Optional: override the data directory (defaults to ./data)
# DATA_DIR=./data

# Optional: override individual data files
# SYNONYMS_CSV_PATH=./data/target_synonyms.csv
# DRUG_DATA_XLSX_PATH=./data/drug_data.xlsx
# PREFERRED_TERMS_XLSX_PATH=./data/preferred_terms.xlsx
# CROSSTALK_CSV_PATH=./data/crosstalk_ids.csv
# SUMMARY_DELTAS_CSV_PATH=./data/summary_deltas.csv

# Optional runtime behavior
# 1 = full dataset, 0.1 = 10% sample
DRUG_SAMPLE_FRACTION=1
# Set true only for demo-only randomized "new info" dots
INJECT_DEMO_NEW_INFO=false

# Pipeline adapter settings
# EXCEL_V2_ROOT=../excel_v2
# CITELINE_API_ROOT=../api/citeline_api_example
# PIPELINE_OUTPUT_ROOT=output/portal_pipeline_runs
# PIPELINE_PYTHON_BIN=python3
# PIPELINE_STEP_TIMEOUT_SECONDS=21600
# PIPELINE_QUEUE_CONCURRENCY=1
# PIPELINE_RUN_STORE_PATH=./data/pipeline_runs.json

# Optional pipeline API-key RBAC (token:role pairs)
# PIPELINE_API_KEYS=viewerToken:viewer,operatorToken:operator,adminToken:admin
